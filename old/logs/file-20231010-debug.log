2023-10-10T15:46:59-03:00 DEBUG GenericDAO SELECT solicitudcategorizacion.*, docente.cd_docente as docente_oid , docente.ds_nombre as docente_ds_nombre , docente.ds_apellido as docente_ds_apellido , docente.nu_documento as docente_nu_documento , docente.nu_precuil as docente_nu_precuil , docente.nu_postcuil as docente_nu_postcuil , facultad.cd_facultad as facultad_oid , facultad.ds_facultad as facultad_ds_facultad , FacultadPlanilla.cd_facultad as FacultadPlanilla_oid , FacultadPlanilla.ds_facultad as FacultadPlanilla_ds_facultad , periodo.cd_periodo as periodo_oid , periodo.ds_periodo as periodo_ds_periodo , cat.cd_cat as cat_oid , cat.ds_cat as cat_ds_cat , estadocategorizacion.cd_estado as estadocategorizacion_oid , estadocategorizacion.ds_estado as estadocategorizacion_ds_estado , cyt_solicitudcategorizacion_estado.oid as cyt_solicitudcategorizacion_estado_oid , cyt_solicitudcategorizacion_estado.fechaDesde as cyt_solicitudcategorizacion_estado_fechaDesde , cyt_solicitudcategorizacion_estado.fechaHasta as cyt_solicitudcategorizacion_estado_fechaHasta , unidad.cd_unidad as unidad_oid , unidad.ds_unidad as unidad_ds_unidad , unidad.ds_sigla as unidad_ds_sigla , cargo.cd_cargo as cargo_oid , cargo.ds_cargo as cargo_ds_cargo , deddoc.cd_deddoc as deddoc_oid , deddoc.ds_deddoc as deddoc_ds_deddoc , facultad.cd_facultad as facultad_oid , facultad.ds_facultad as facultad_ds_facultad , LugarTrabajoBeca.cd_unidad as LugarTrabajoBeca_oid , LugarTrabajoBeca.ds_unidad as LugarTrabajoBeca_ds_unidad , LugarTrabajoBeca.ds_sigla as LugarTrabajoBeca_ds_sigla , LugarTrabajoCarrera.cd_unidad as LugarTrabajoCarrera_oid , LugarTrabajoCarrera.ds_unidad as LugarTrabajoCarrera_ds_unidad , LugarTrabajoCarrera.ds_sigla as LugarTrabajoCarrera_ds_sigla , carrerainv.cd_carrerainv as carrerainv_oid , carrerainv.ds_carrerainv as carrerainv_ds_carrerainv , organismo.cd_organismo as organismo_oid , organismo.ds_organismo as organismo_ds_organismo , categoria.cd_categoria as categoria_oid , categoria.ds_categoria as categoria_ds_categoria , equivalencia.cd_equivalencia as equivalencia_oid , equivalencia.ds_equivalencia as equivalencia_ds_equivalencia , categoriasicadi.cd_categoriasicadi as categoriasicadi_oid , categoriasicadi.ds_categoriasicadi as categoriasicadi_ds_categoriasicadi , titulo.cd_titulo as titulo_oid , titulo.ds_titulo as titulo_ds_titulo , Tituloposgrado.cd_titulo as Tituloposgrado_oid , Tituloposgrado.ds_titulo as Tituloposgrado_ds_titulo , area.cd_area as area_oid , area.ds_area as area_ds_area , subarea.cd_subarea as subarea_oid , subarea.ds_subarea as subarea_ds_subarea  FROM solicitudcategorizacion LEFT JOIN facultad FacultadPlanilla ON(solicitudcategorizacion.cd_facultadplanilla = FacultadPlanilla.cd_facultad) LEFT JOIN docente ON(solicitudcategorizacion.cd_docente = docente.cd_docente) LEFT JOIN periodo ON(solicitudcategorizacion.cd_periodo = periodo.cd_periodo) LEFT JOIN cat ON(FacultadPlanilla.cd_cat = cat.cd_cat) LEFT JOIN cyt_solicitudcategorizacion_estado ON(cyt_solicitudcategorizacion_estado.solicitud_oid = solicitudcategorizacion.cd_solicitud) LEFT JOIN estadocategorizacion ON(cyt_solicitudcategorizacion_estado.estado_oid = estadocategorizacion.cd_estado) LEFT JOIN unidad ON(solicitudcategorizacion.cd_unidad = unidad.cd_unidad) LEFT JOIN cargo ON(solicitudcategorizacion.cd_cargo = cargo.cd_cargo) LEFT JOIN deddoc ON(solicitudcategorizacion.cd_deddoc = deddoc.cd_deddoc) LEFT JOIN facultad ON(solicitudcategorizacion.cd_facultad = facultad.cd_facultad) LEFT JOIN unidad LugarTrabajoBeca ON(solicitudcategorizacion.cd_unidadbeca = LugarTrabajoBeca.cd_unidad) LEFT JOIN unidad LugarTrabajoCarrera ON(solicitudcategorizacion.cd_unidadcarrera = LugarTrabajoCarrera.cd_unidad) LEFT JOIN organismo ON(solicitudcategorizacion.cd_organismo = organismo.cd_organismo) LEFT JOIN carrerainv ON(solicitudcategorizacion.cd_carrerainv = carrerainv.cd_carrerainv) LEFT JOIN categoria ON(solicitudcategorizacion.cd_categoria = categoria.cd_categoria) LEFT JOIN equivalencia ON(solicitudcategorizacion.cd_equivalencia = equivalencia.cd_equivalencia) LEFT JOIN categoriasicadi ON(solicitudcategorizacion.cd_categoriasicadi = categoriasicadi.cd_categoriasicadi) LEFT JOIN titulo ON(solicitudcategorizacion.cd_titulogrado = titulo.cd_titulo) LEFT JOIN titulo Tituloposgrado ON(solicitudcategorizacion.cd_tituloposgrado = Tituloposgrado.cd_titulo) LEFT JOIN area ON(solicitudcategorizacion.cd_areacarrera = area.cd_area) LEFT JOIN subarea ON(solicitudcategorizacion.cd_subareacarrera = subarea.cd_subarea) WHERE  solicitudcategorizacion.cd_periodo = ? AND (fechaHasta is null) ORDER BY solicitudcategorizacion. cd_solicitud DESC  LIMIT ?, ?
2023-10-10T15:46:59-03:00 DEBUG GenericDAO SELECT cyt_solicitudcategorizacion_estado.*, solicitudcategorizacion.cd_solicitud as solicitudcategorizacion_oid , docente.cd_docente as docente_oid , docente.ds_nombre as docente_ds_nombre , docente.ds_apellido as docente_ds_apellido , estadocategorizacion.cd_estado as estadocategorizacion_oid , estadocategorizacion.ds_estado as estadocategorizacion_ds_estado , cyt_user.oid AS cyt_user_oid, CASE cyt_user.ds_name WHEN '' THEN cyt_user.ds_username ELSE cyt_user.ds_name END AS ds_username FROM cyt_solicitudcategorizacion_estado LEFT JOIN solicitudcategorizacion ON(cyt_solicitudcategorizacion_estado.solicitud_oid = solicitudcategorizacion.cd_solicitud) LEFT JOIN docente ON(solicitudcategorizacion.cd_docente = docente.cd_docente) LEFT JOIN estadocategorizacion ON(cyt_solicitudcategorizacion_estado.estado_oid = estadocategorizacion.cd_estado) LEFT JOIN cyt_user ON(cyt_solicitudcategorizacion_estado.user_oid = cyt_user.oid) WHERE  cyt_solicitudcategorizacion_estado.solicitud_oid = ? AND (fechaHasta is null)
