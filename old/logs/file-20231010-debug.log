goria.ds_categoria as categoria_ds_categoria , equivalencia.cd_equivalencia as equivalencia_oid , equivalencia.ds_equivalencia as equivalencia_ds_equivalencia , categoriasicadi.cd_categoriasicadi as categoriasicadi_oid , categoriasicadi.ds_categoriasicadi as categoriasicadi_ds_categoriasicadi , titulo.cd_titulo as titulo_oid , titulo.ds_titulo as titulo_ds_titulo , Tituloposgrado.cd_titulo as Tituloposgrado_oid , Tituloposgrado.ds_titulo as Tituloposgrado_ds_titulo , area.cd_area as area_oid , area.ds_area as area_ds_area , subarea.cd_subarea as subarea_oid , subarea.ds_subarea as subarea_ds_subarea  FROM solicitudcategorizacion LEFT JOIN facultad FacultadPlanilla ON(solicitudcategorizacion.cd_facultadplanilla = FacultadPlanilla.cd_facultad) LEFT JOIN docente ON(solicitudcategorizacion.cd_docente = docente.cd_docente) LEFT JOIN periodo ON(solicitudcategorizacion.cd_periodo = periodo.cd_periodo) LEFT JOIN cat ON(FacultadPlanilla.cd_cat = cat.cd_cat) LEFT JOIN cyt_solicitudcategorizacion_estado ON(cyt_solicitudcategorizacion_estado.solicitud_oid = solicitudcategorizacion.cd_solicitud) LEFT JOIN estadocategorizacion ON(cyt_solicitudcategorizacion_estado.estado_oid = estadocategorizacion.cd_estado) LEFT JOIN unidad ON(solicitudcategorizacion.cd_unidad = unidad.cd_unidad) LEFT JOIN cargo ON(solicitudcategorizacion.cd_cargo = cargo.cd_cargo) LEFT JOIN deddoc ON(solicitudcategorizacion.cd_deddoc = deddoc.cd_deddoc) LEFT JOIN facultad ON(solicitudcategorizacion.cd_facultad = facultad.cd_facultad) LEFT JOIN unidad LugarTrabajoBeca ON(solicitudcategorizacion.cd_unidadbeca = LugarTrabajoBeca.cd_unidad) LEFT JOIN unidad LugarTrabajoCarrera ON(solicitudcategorizacion.cd_unidadcarrera = LugarTrabajoCarrera.cd_unidad) LEFT JOIN organismo ON(solicitudcategorizacion.cd_organismo = organismo.cd_organismo) LEFT JOIN carrerainv ON(solicitudcategorizacion.cd_carrerainv = carrerainv.cd_carrerainv) LEFT JOIN categoria ON(solicitudcategorizacion.cd_categoria = categoria.cd_categoria) LEFT JOIN equivalencia ON(solicitudcategorizacion.cd_equivalencia = equivalencia.cd_equivalencia) LEFT JOIN categoriasicadi ON(solicitudcategorizacion.cd_categoriasicadi = categoriasicadi.cd_categoriasicadi) LEFT JOIN titulo ON(solicitudcategorizacion.cd_titulogrado = titulo.cd_titulo) LEFT JOIN titulo Tituloposgrado ON(solicitudcategorizacion.cd_tituloposgrado = Tituloposgrado.cd_titulo) LEFT JOIN area ON(solicitudcategorizacion.cd_areacarrera = area.cd_area) LEFT JOIN subarea ON(solicitudcategorizacion.cd_subareacarrera = subarea.cd_subarea) WHERE  solicitudcategorizacion.cd_periodo = ? AND (fechaHasta is null) ORDER BY solicitudcategorizacion. cd_solicitud DESC  LIMIT ?, ?
